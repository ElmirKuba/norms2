# Монорепо без workspace: сборочные/зависимостные игноры — у каждого подпроекта
# свои (nest/.gitignore, angular/.gitignore). В корне нет package.json, поэтому
# node_modules/dist тут не появляются. Здесь — только репо-уровневое.

# Env / секреты (корневой .env, напр. для docker-compose)
.env
.env.*
!.env.example

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp

