# Prod-образ бэкенда (NestJS), multi-stage. Контекст сборки — корень репозитория.
# Чистый рантайм без dev-зависимостей; Drizzle-миграции прогоняются отдельным
# шагом деплоя (см. docs/deployment.md), не в этом образе.

# ── Стадия сборки ──
FROM node:24 AS build
WORKDIR /app
COPY nest/package.json nest/package-lock.json ./
RUN npm ci
COPY nest/ ./
RUN npm run build

# ── Стадия рантайма ──
FROM node:24-slim AS run
WORKDIR /app
ENV NODE_ENV=production
COPY nest/package.json nest/package-lock.json ./
RUN npm ci --omit=dev
COPY --from=build /app/dist ./dist
# SQL-миграции (+ meta/journal) для one-shot мигратора `node dist/migrate.js` (D1.2):
# drizzle-kit в рантайм-образе нет, но drizzle-orm/migrator читает эти файлы.
COPY --from=build /app/drizzle ./drizzle
# Авторские seed-файлы релиз-нот (F7) — сид копирует их в CONTENT_DIR при старте.
COPY nest/seed-content ./seed-content
# Версия продукта (единый source of truth, ADR-0044) — бэк читает в GET /version.
COPY VERSION ./VERSION

# git-SHA билда для GET /version (ADR-0044). В проде .git нет — SHA только отсюда.
# Прокидывать при сборке: --build-arg GIT_COMMIT=$(git rev-parse --short HEAD).
ARG GIT_COMMIT=""
ENV GIT_COMMIT=$GIT_COMMIT

EXPOSE 3000

CMD ["node", "dist/main.js"]
