# Пример переменных окружения «Нормисов». Скопировать в .env и заполнить.
# .env в git НЕ коммитится. В коде читаются только через ConfigService (zod,
# fail-fast) — никогда process.env напрямую (CLAUDE.md, ADR-0019).
# Полные описания — docs/backend.md и docs/deployment.md.
# Без inline-комментариев в строках VAR=value: файл подхватывает и Makefile
# (include .env), а Make трактует # как комментарий в любом месте строки.

NODE_ENV=development

# ── PostgreSQL ──
# DB_HOST=localhost — для бэка/тулинга на хосте (postgres опубликован на localhost).
# В Docker сам nest-контейнер переопределяет DB_HOST на имя контейнера БД (compose).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=norms2
DB_USER=norms2
# Dev-значение; в проде — секрет вне репозитория.
DB_PASSWORD=norms2

# ── pgAdmin (только dev) ──
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=8081

# ── Порты приложений ──
BACKEND_PORT=3000
FRONTEND_PORT=4200
# CORS-origin фронта (dev, кросс-порт). В проде пусто (same-origin за Traefik).
CORS_ORIGIN=http://localhost:4200

# ── Авторизация / JWT (заполнить своим секретом!) ──
# ≥32 символов из CSPRNG, напр.: openssl rand -base64 36
JWT_ACCESS_SECRET=change-me-to-a-32-plus-char-random-secret
ACCESS_TTL=15m
REFRESH_TTL=30d
# true в проде (refresh-cookie только по HTTPS).
COOKIE_SECURE=false

# ── Бизнес-флаги фазы 1 ──
# dev: открытая рега; прод — false (invite-only).
FREE_REGISTRATION=true
INVITE_DEFAULT_QUOTA=3
INVITE_TTL_DAYS=3
AVATAR_MAX_BYTES=512000
# Попыток optimistic-lock retry на правках профиля (ADR-0035).
OPTIMISTIC_RETRY_ATTEMPTS=3

# ── Тюнеры раздела «Акцент» (опц.; есть дефолты в коде, env-схема) ──
# Макс. глубина дерева целей (ADR-0052; дефолт 2 = 1 уровень подцелей):
# ACCENT_GOAL_MAX_DEPTH=2
# Мягкий порог «в фокусе» целей (ADR-0053; дефолт 3; сверх — вопрос, не блок):
# ACCENT_GOAL_FOCUS_SOFT_LIMIT=3

# ── Версия (ADR-0044) ──
# Версия продукта «Нормисы» — в файле VERSION в корне репо (единый source of truth);
# бэк читает его и отдаёт в GET /version. В .env версии нет.
# GIT_COMMIT здесь НЕ задаём: dev читает .git живьём, прод — build ARG. Пустой
# GIT_COMMIT в .env перебил бы оба → не добавлять.

# ── Прод (docker-compose.prod.yml, Traefik + Let's Encrypt) ──
# Раскомментировать и заполнить при настройке VPS.
# DOMAIN=нормисы.рф
# ACME_EMAIL=admin@example.com
