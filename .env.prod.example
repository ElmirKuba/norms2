# Пример ПРОД-окружения «Нормисов». На сервере скопировать в .env и заполнить
# секретами (вне репозитория!). Прод-compose читает тот же файл .env.
# Полные описания — docs/deployment.md. Без inline-комментариев в строках VAR=value.

NODE_ENV=production

# ── PostgreSQL ──
# В прод-сети nest ходит в БД по имени контейнера (compose переопределяет DB_HOST
# на norms2_postgres_prod). Здесь — для тулинга/миграций в той же сети.
DB_HOST=norms2_postgres_prod
DB_PORT=5432
DB_NAME=norms2
DB_USER=norms2
# СИЛЬНЫЙ пароль (сгенерировать; не коммитить).
DB_PASSWORD=CHANGE_ME_STRONG

# ── Авторизация / JWT (СГЕНЕРИРОВАТЬ сильные секреты!) ──
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH
ACCESS_TTL=15m
REFRESH_TTL=30d
# true в проде — refresh-cookie только по HTTPS (за Traefik + trust proxy).
COOKIE_SECURE=true

# ── CORS ──
# Пусто в проде: фронт и API за одним origin (Traefik path-based) → CORS не нужен.
CORS_ORIGIN=

# ── Бизнес-флаги ──
FREE_REGISTRATION=false
INVITE_DEFAULT_QUOTA=3
INVITE_TTL_DAYS=3
AVATAR_MAX_BYTES=512000
OPTIMISTIC_RETRY_ATTEMPTS=3

# ── Версия ──
# Версия продукта (единый source of truth, ADR-0044).
PRODUCT_VERSION=1.0.0
# GIT_COMMIT здесь НЕ задавать — он инжектится в образ как build ARG
# (Makefile: git rev-parse --short HEAD). В .env переопределил бы его пустым.

# ── Прод-домен / TLS (Traefik + Let's Encrypt) ──
# DOMAIN — в PUNYCODE (IDN): нормисы.рф → xn--h1ahceki4e.xn--p1ai.
DOMAIN=xn--h1ahceki4e.xn--p1ai
ACME_EMAIL=you@example.com
