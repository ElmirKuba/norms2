# Пример переменных окружения «Нормисов». Скопировать в .env и заполнить.
# .env в git НЕ коммитится. В коде читаются только через ConfigService (zod,
# fail-fast) — никогда process.env напрямую (CLAUDE.md, ADR-0019).
# Полные описания — docs/backend.md и docs/deployment.md.

# ── Режим ──
NODE_ENV=development

# ── PostgreSQL ──
DB_HOST=norms2_postgres_dev   # имя контейнера в Docker-сети; для запуска nest на хосте — localhost
DB_PORT=5432
DB_NAME=norms2
DB_USER=norms2
DB_PASSWORD=norms2            # dev-значение; в проде — секрет вне репозитория

# ── pgAdmin (только dev) ──
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=8081

# ── Порты приложений ──
BACKEND_PORT=3000
FRONTEND_PORT=4200

# ── Авторизация / JWT (заполнить своими секретами!) ──
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
ACCESS_TTL=15m
REFRESH_TTL=30d
COOKIE_SECURE=false           # true в проде (refresh-cookie только по HTTPS)

# ── Бизнес-флаги фазы 1 ──
FREE_REGISTRATION=true        # dev: открытая рега; прод — false (invite-only)
INVITE_DEFAULT_QUOTA=3
INVITE_TTL_DAYS=3
AVATAR_MAX_BYTES=512000

# ── Прод (docker-compose.prod.yml, Traefik + Let's Encrypt) ──
# DOMAIN=нормисы.рф
# ACME_EMAIL=admin@example.com
